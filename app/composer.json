{
    "name": "loan/api",
    "description": "Loan Application REST API",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "yiisoft/yii2": "~2.0.49"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "friendsofphp/php-cs-fixer": "^3"
    },
    "autoload": {
        "psr-4": {
            "app\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "app\\tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "config": {
        "vendor-dir": "vendor",
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "extra": {
        "yii\\composer\\Installer::postCreateProject": {
            "setPermission": [
                {
                    "runtime": "0755"
                }
            ]
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "test:unit": "phpunit --testsuite Unit --testdox",
        "test:functional": "phpunit --testsuite Functional --testdox",
        "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.php",
        "cs-check": "php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff"
    },
    "minimum-stability": "stable"
}
